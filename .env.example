# Real secrets live in the launchd plist EnvironmentVariables on macOS,
# not in .env. .env is for local-dev MCP servers only.
#
# The OpenClaw gateway reads `process.env`, populated on macOS launchd by the
# plist EnvironmentVariables dict. ${ENV_VAR} references in mcporter.json are
# resolved from that source — NOT from .env files.
#
# This file documents which env vars an adopter needs to set in two places:
#   1. Local dev: in .env (for testing in-repo MCP servers outside the gateway)
#   2. Runtime host: in deploy/com.example.openclaw-deploy.plist.template
#
# Copy this file to .env (gitignored) and fill in real values for local dev.

# Anthropic API key (agent runtime).
# Per-cron keys (ANTHROPIC_API_KEY_<CRON_NAME>) optional; see OC_KB_05 + OC_KB_06.
ANTHROPIC_API_KEY=

# Deploy webhook HMAC secret. Must match the secret configured in the GitHub webhook.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# Add per-MCP-server tokens here as adopters add MCP integrations.
# Each ${ENV_VAR} reference in workspace/config/mcporter.json must be listed here.
# Example:
# GMAIL_OAUTH_TOKEN=
# SLACK_BOT_TOKEN=
